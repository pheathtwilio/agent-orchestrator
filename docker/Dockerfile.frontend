# Frontend agent: extends base with browser tooling
FROM ao-agent:latest

USER root

# Playwright and browser dependencies
RUN npx playwright install-deps chromium \
    && npx playwright install chromium

# Append frontend skill instructions to base CLAUDE.md
COPY docker/skills/frontend/CLAUDE.md /tmp/frontend-skill.md
RUN cat /tmp/frontend-skill.md >> /workspace/.claude/CLAUDE.md && rm /tmp/frontend-skill.md

USER agent
