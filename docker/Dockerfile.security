# Security agent: extends base with scanning tools
FROM ao-agent:latest

USER root

RUN npm install -g snyk \
    && curl -fsSL https://raw.githubusercontent.com/returntocorp/semgrep/develop/setup.sh | bash || true \
    && apt-get update && apt-get install -y python3 python3-pip \
    && pip3 install --break-system-packages semgrep \
    && rm -rf /var/lib/apt/lists/*

USER agent
