# Security agent: extends base with scanning tools
FROM ao-agent:latest

USER root

RUN npm install -g snyk \
    && apt-get update && apt-get install -y python3 python3-pip \
    && pip3 install --break-system-packages semgrep \
    && rm -rf /var/lib/apt/lists/*

# Append security skill instructions to base CLAUDE.md
COPY docker/skills/security/CLAUDE.md /tmp/security-skill.md
RUN cat /tmp/security-skill.md >> /workspace/.claude/CLAUDE.md && rm /tmp/security-skill.md

USER agent
