# Base image for all agent containers.
# Skill-specific images extend this with additional tooling.
#
# Auth modes (set via environment variables at runtime):
#   1. AWS SSO / Bedrock: mount ~/.aws read-only, set CLAUDE_CODE_USE_BEDROCK=1
#   2. Personal API key: set ANTHROPIC_API_KEY
FROM node:20-bookworm

# System dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    ripgrep \
    less \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# AWS CLI (for Bedrock SSO auth mode)
RUN curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "/tmp/awscliv2.zip" \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && /tmp/aws/install \
    && rm -rf /tmp/aws /tmp/awscliv2.zip

# Claude Code CLI (runs with --dangerously-skip-permissions)
RUN npm install -g @anthropic-ai/claude-code

# Create non-root agent user
RUN useradd -m -s /bin/bash agent \
    && mkdir -p /workspace /workspace/.claude /home/agent/.claude \
    && chown -R agent:agent /workspace /home/agent/.claude

# Copy base skill CLAUDE.md (skill-specific images append to this)
COPY docker/skills/base/CLAUDE.md /workspace/.claude/CLAUDE.md

# Copy Claude settings that grant full permissions (for --dangerously-skip-permissions)
COPY docker/config/settings.json /home/agent/.claude/settings.json
COPY docker/config/settings.local.json /home/agent/.claude/settings.local.json
RUN chown -R agent:agent /home/agent/.claude

# Copy entrypoint that handles auth detection
COPY docker/scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER agent
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
